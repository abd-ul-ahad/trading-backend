const path = require('path');

// Load env vars before anything else so the CLI sees DB_* variables.
require('dotenv').config();

// Register ts-node so sequelize-cli can load .ts migrations directly.
// We use a dedicated tsconfig (CommonJS) because sequelize-cli requires() files,
// and the main tsconfig uses nodenext which is incompatible with require().
require('ts-node').register({
  project: path.resolve(__dirname, 'tsconfig.cli.json'),
  transpileOnly: true,
});

module.exports = {
  config: path.resolve('src', 'config', 'database.js'),
  'models-path': path.resolve('src', 'database', 'models'),
  'seeders-path': path.resolve('database', 'seeders'),
  'migrations-path': path.resolve('database', 'migrations'),
};
